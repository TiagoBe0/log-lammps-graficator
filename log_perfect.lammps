System init for write_data ...
thermo 1000

#(5) Velocidades iniciales
velocity	all create 300.0 482748 dist gaussian

## Calculos por atomo
compute 1 all ke/atom
compute 3 all pe/atom
compute 4 all stress/atom NULL

## Von Mises promedio
variable J2 equal sqrt(0.5*((pxx-pyy)^2+(pxx-pzz)^2+(pzz-pyy)^2+6*(pxy^2+pxz^2+pyz^2)))

thermo 100
thermo_style custom step temp ke pe etotal press pxx pyy pzz pxy pxz pyz ly lx lz v_J2 cellalpha cellbeta cellgamma xy xz yz
thermo_modify	lost warn norm yes

#(6) Equilibrado: rampa a 1500 K y 150 GPa, luego hold
fix upTemp all  temp/rescale 1 300.0 1500.0 1.0 1.0
fix upPress all nph aniso 0.0 1500000.0 0.30 drag 1.50
run		5000
